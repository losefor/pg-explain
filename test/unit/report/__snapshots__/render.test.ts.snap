"{
  "schemaVersion": 1,
  "verdict": "4 warnings — top cost: Index Scan using users_pkey on users (u) (94% of time). Total 4.25 s.",
  "worstSeverity": "warn",
  "summary": {
    "planningTimeMs": 0.55,
    "executionTimeMs": 4250,
    "serializationTimeMs": null,
    "hasAnalyze": true,
    "hasBuffers": false,
    "nodeCount": 3,
    "findings": {
      "error": 0,
      "warn": 4,
      "info": 0
    }
  },
  "triggers": [],
  "jit": null,
  "settings": null,
  "diagnostics": [
    {
      "code": "PGX_NESTED_LOOP_LARGE_OUTER",
      "domain": "plan",
      "severity": "warn",
      "title": "Nested loop driven by 50,000 outer rows (Seq Scan on events (e))",
      "detail": "The nested loop's outer side (Seq Scan on events (e)) produced 50,000 rows, so its inner side (Index Scan using users_pkey on users (u)) is re-executed roughly that many times.",
      "cause": "The planner expected far fewer outer rows than the 50,000 that actually came back, so it chose a per-row nested loop where a single hash/merge join would have been cheaper.",
      "remediation": {
        "summary": "Fix the outer-side row estimate first — re-ANALYZE events, raise its column statistics, or add extended statistics — so the planner switches to a hash or merge join. If the estimate is already accurate, add an index on the inner join key ((u.id = e.user_id)) so each of the 50,000 probes is cheap.",
        "steps": [
          "Compare the outer node's estimated vs actual rows: a large gap means the estimate is the real problem.",
          "Refresh statistics so the planner sees the true cardinality and can prefer a hash/merge join.",
          "If columns are correlated, create extended (multivariate) statistics on them.",
          "If estimates are already correct, index the inner join key so each probe is an index lookup, not a scan.",
          "As a last resort to confirm the diagnosis, test with \`SET enable_nestloop = off\` for this query only."
        ],
        "commands": [
          {
            "label": "Refresh planner statistics on the driving table",
            "sql": "ANALYZE events;"
          },
          {
            "label": "Increase statistics target on the misestimated column, then re-ANALYZE",
            "sql": "ALTER TABLE events ALTER COLUMN <column> SET STATISTICS 1000;\\nANALYZE events;"
          },
          {
            "label": "Add extended statistics for correlated columns",
            "sql": "CREATE STATISTICS events_stats (dependencies, ndistinct) ON <col_a>, <col_b> FROM events;\\nANALYZE events;"
          },
          {
            "label": "If estimates are correct, index the inner join key",
            "sql": "CREATE INDEX ON users (<inner join column>);"
          },
          {
            "label": "Confirm the diagnosis by disabling nested loops for this query only",
            "sql": "SET enable_nestloop = off;"
          }
        ]
      },
      "location": {
        "kind": "node",
        "nodeId": 0,
        "nodeType": "Nested Loop"
      },
      "docsUrl": "https://www.postgresql.org/docs/current/runtime-config-query.html",
      "meta": {
        "outerRows": 50000
      }
    },
    {
      "code": "PGX_ROW_MISESTIMATE",
